---
import BaseLayout from "@/layouts/BaseLayout.astro";

const fm = Astro.props.frontmatter ?? Astro.props;
const title = fm?.title ?? Astro.props.title ?? "Blog";
const pubDate = fm?.pubDate ?? Astro.props.pubDate;
const description = fm?.description ?? Astro.props.description;
const tags = fm?.tags ?? Astro.props.tags;
---

<BaseLayout title={title}>
  {
    title && title !== "Blog" ? (
      <article class="post">
        <header class="post-header">
          <h1 class="post-title">{title}</h1>
          {pubDate ? (
            <time class="post-date">
              {new Date(pubDate).toLocaleDateString()}
            </time>
          ) : null}
          {tags ? (
            <p class="post-tags">
              {Array.isArray(tags) ? tags.join(", ") : String(tags)}
            </p>
          ) : null}
          {description ? <p class="post-desc">{description}</p> : null}
        </header>

        <section class="post-content">
          <slot />
        </section>
      </article>
    ) : (
      <slot />
    )
  }
</BaseLayout>
